<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="dev.dong4j.zeka.stack.api.project.dao.ProjectMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="ProjectResultMap" type="dev.dong4j.zeka.stack.api.project.entity.po.Project">
        <result column="id" property="id"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="key" property="key"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="repos" property="repos"/>
        <result column="icon" property="icon"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="all_field">
        a.id,
        a.`key`,
        a.`name`,
        a.`description`,
        a.`repos`,
        a.`icon`,
        a.`sort_order`,
        a.`status`,
        a.create_time,
        a.update_time
    </sql>

    <sql id="date_query">
        <if test="query.startTime != null">
            <![CDATA[
                and a.create_time >= #{query.startTime}
            ]]>
        </if>
        <if test="query.endTime != null">
            <![CDATA[
                and a.create_time < #{query.endTime}
            ]]>
        </if>
    </sql>

    <select id="page" resultType="dev.dong4j.zeka.stack.api.project.entity.dto.ProjectDTO"
            parameterType="dev.dong4j.zeka.stack.api.project.entity.form.ProjectQuery">
        select
        <include refid="all_field"/>
        from project as a
        <where>
            <include refid="date_query"/>
        </where>
        order by create_time desc
    </select>
</mapper>
